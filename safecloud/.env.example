SAFECLOUD_APP_NAME=SafeCloud
SAFECLOUD_API_PREFIX=/api
SAFECLOUD_DATABASE_URL=sqlite:///./safecloud.db
SAFECLOUD_CORS_ORIGINS=*
SAFECLOUD_ONLINE_TIMEOUT_SECONDS=120
SAFECLOUD_THRESHOLD_TEMPERATURE=45
SAFECLOUD_THRESHOLD_HUMIDITY=85
SAFECLOUD_THRESHOLD_GAS=300
SAFECLOUD_THRESHOLD_SMOKE=200
SAFECLOUD_THRESHOLD_NOISE=85
SAFECLOUD_THRESHOLD_VOLTAGE=250
SAFECLOUD_THRESHOLD_CURRENT=20
